# OODA Environment Variables

# Database (SQLite for MVP)
DATABASE_URL=sqlite:///./ooda.db

# ── Data Mode ────────────────────────────────────────────────────────────────
# "demo"   = seeded data only (no external APIs)
# "live"   = real API integrations only
# "hybrid" = try real APIs first, fallback to seeded/demo data (recommended)
DATA_MODE=hybrid

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "openrouter" = use OpenRouter cloud API first (recommended)
# "ollama"     = use local Ollama first
# "auto"       = try OpenRouter if key exists, then Ollama, then fallback
LLM_PROVIDER=openrouter

# ── Open-Source / Local LLM ──────────────────────────────────────────────────
OPEN_SOURCE_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b

# ── Cloud LLM (OpenRouter) ──────────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat

OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=OODA

# ── External API Keys ────────────────────────────────────────────────────────
NEWS_API_KEY=
SERPAPI_KEY=
GITHUB_TOKEN=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
